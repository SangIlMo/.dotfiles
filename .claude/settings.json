{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [
      "Bash(git * --no-verify*)",
      "Bash(gh api */git/refs*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/korean-branch-trigger.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.claude/rules/*.md"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "agents-observe@agents-observe": true,
    "annotate-pr@git-change-reviewer": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agents-observe": {
      "source": {
        "source": "github",
        "repo": "simple10/agents-observe"
      }
    }
  },
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "additionalDirectories": [
    "~/notes/obsidian-vault"
  ]
}
